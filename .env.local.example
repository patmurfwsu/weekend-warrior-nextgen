# Copy this file to .env.local and fill in your values

# Google Maps JavaScript API — needs "Maps JavaScript API" and "Places API" enabled
# Get a key at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe — for the donate page
# Get keys at: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Formspree — for the submit airport form
# Create a form at: https://formspree.io and paste the form ID here
FORMSPREE_ID=your_formspree_form_id_here
